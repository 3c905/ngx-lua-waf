# [core]

# 隐藏文件（根路径下以 . 开头的文件/目录）
# .well-known 通过 wafconf/whiteurl 放行
# -> 隐藏文件/目录访问
^/\..*$

# Spring Boot Actuator 敏感端点（不含 health）
# -> Spring Boot Actuator 敏感端点
^/actuator/(env|beans|heapdump|threaddump|metrics|prometheus|mappings|configprops|loggers|conditions|caches|scheduledtasks)$

# Swagger / OpenAPI
# -> Swagger API 文档泄露
swagger\.json
# -> Swagger UI 入口
^/swagger-ui(/.*)?$
# -> Swagger 资源接口
^/swagger-resources(/.*)?$
# -> Swagger v2 API 文档
^/v2/api-docs(/.*)?$
# -> OpenAPI v3 API 文档
^/v3/api-docs(/.*)?$
# -> OpenAPI 文档
^/openapi\.json$
# -> ReDoc 文档
^/redoc$

# phpinfo / 状态页
# -> phpinfo 信息页
^/phpinfo\.php$
# -> info 信息页
^/info\.php$
# -> Nginx 状态页
^/nginx_status$
# -> Apache 状态页
^/server-status$

# 调试工具
# -> Go pprof 调试接口
^/debug/pprof(/.*)?$
# -> Debugbar 调试工具
^/_debugbar(/.*)?$

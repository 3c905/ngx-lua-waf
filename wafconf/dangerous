^/_profiler(/.*)?$

# AI / Notebook / LLM Debug
# -> AI/Notebook 平台入口
^/(gradio|streamlit|jupyter|notebook)(/.*)?$

# 补充屏蔽路径
^/(shell|cmd|webshell|c99|r57)\.
# -> WordPress 后台/配置入口
^/wp-(login|config|admin)

# 常见 CMS / 框架后台入口与安装目录探测
# -> 通用 admin.php 入口
^/admin\.php$
# -> 通用 admin 登录页
^/admin/login\.php$
# -> 应用后台入口
^/apps/admin(/.*)?$
# -> 应用安装目录
^/app/install(/.*)?$
# -> 安装控制器目录
^/install/controller(/.*)?$
# -> 静态资源后台路径
^/public/static/admin(/.*)?$
# -> 上传图片目录脚本执行
^/static/upload/image/.*\.(php\d*|jsp|asp|aspx|sh|py|pl)$
# -> 可疑 PHP 文件 dd.php
^/dd\.php$

# 上传目录禁止执行脚本（扩展覆盖常见上传目录）
# -> 上传目录脚本执行
^/(upload|uploads|uploadfiles?|upimg|attachment|attachments|static/upload)/.*\.(php\d*|jsp|jspx|asp|aspx|cgi|py|sh|pl|rb)$


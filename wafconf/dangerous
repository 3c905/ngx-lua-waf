# -> 开发服务器元数据上传接口
/developmentserver/metadatauploader
# -> Spring Cloud Gateway 路由泄露
/actuator/gateway/routes
# -> Spring Cloud Gateway 刷新接口
/actuator/gateway/refresh
# -> Gateway 路由接口
/api/v1/gateway/routes
# -> WebLogic WS-UTC 配置漏洞
/ws_utc/config\.do
# -> WebLogic 控制台路径穿越
/console/css/%252e
# -> WebLogic async 反序列化
/_async/AsyncResponseService
# -> WebLogic wls-wsat 反序列化
/wls-wsat/CoordinatorPortType
# -> JBoss invoker 反序列化
/invoker/readonly
# -> JBoss WebServices 接口
/jbossws/services
# -> Axis2 管理后台
/axis2/axis2-admin
# -> Solr 管理接口
/solr/admin/cores
# -> 致远 OA htmlofficeservlet 漏洞
/seeyon/htmlofficeservlet
# -> 泛微 OA BshServlet 漏洞
/weaver/bsh\.servlet\.BshServlet
# -> UEditor 上传漏洞

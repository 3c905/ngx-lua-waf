# [aggressive]

# 所有 Actuator（含 health，K8s 探针会失效）
# -> 激进模式：所有 Actuator 端点
^/actuator(/.*)?$

# 极度宽泛的 debug 匹配（误伤 /api/debug-mode 等正常路径）
# -> 激进模式：宽泛 debug 路径匹配
^/.*debug.*/.*$

# 系统功能 / 健康检查（K8s liveness/readiness 常用）
# -> 激进模式：系统功能接口
^/system-features$
# -> 激进模式：健康检查接口
^/health$
# -> 激进模式：K8s healthz
^/healthz$
# -> 激进模式：K8s livez
^/livez$
# -> 激进模式：K8s readyz
^/readyz$
# -> 激进模式：K8s startupz
^/startupz$

# 状态 / Metrics（Prometheus 监控常用）
# -> 激进模式：状态接口
^/status$
# -> 激进模式：Metrics 接口
^/metrics(/.*)?$
# -> 激进模式：Prometheus 接口
^/prometheus$

# 根路径敏感/调试目录（test 太常见，易误伤）
# -> 激进模式：调试/测试/临时目录
^/(backup|backups|test|tests|debug|tmp|temp|logs|dev|staging|sandbox)(/.*)?$

# 所有非 robots.txt 的 txt（误伤 /license.txt /changelog.txt 等）
# -> 激进模式：除 robots.txt 外的 txt 文件
/(?!robots).*\.txt$

# 脚本 / 源码 / SourceMap 扩展名（技术类/代码分享站点会误伤）
# -> 激进模式：Java 源码/字节码文件
\.(java|class|jar|war)$
# -> 激进模式：Python 源码/字节码
\.(py|pyc|pyo)$
# -> 激进模式：Shell 脚本
\.(sh|bash|zsh|ksh|csh)$
# -> 激进模式：SourceMap 文件
\.map$

# 日志扩展名（若业务提供日志下载会误伤）
# -> 激进模式：日志文件
\.(log|trace|out|err)$

# 备份 / 临时 / 示例扩展名（.dist / .sample 常用于配置示例）

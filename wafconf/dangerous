# 危险文件扩展名 — 配置 / 密钥 / 数据库 / 压缩包 / PHP 备份
# -> 敏感配置文件泄露
\.(env|ini|conf|config|properties|yml|yaml)$
# -> 密钥/证书文件泄露
\.(pem|key|p12|pfx|jks|keystore|truststore|kdb|csr|der)$
# -> Terraform 状态文件泄露
\.(tf|tfvars|tfstate|tfstate\.backup)$
# -> 压缩包文件泄露
\.(7z|zip|rar|tar|tgz|tbz2|txz|gz|bz2|xz|lz|lzma|zst|br)$
# -> 数据库/堆转储文件泄露
\.(sql|sqlite|sqlite3|db|db3|mdb|accdb|dump|dmp|hprof|heapdump)$
# -> PHP 源码/备份泄露
\.(php\d+|php\.bak|php~)$

# 敏感文件模式 — SSH 密钥
# -> SSH 密钥文件泄露
(id_(rsa|dsa|ecdsa|ed25519)|authorized_keys|known_hosts)$

# 敏感文件模式 — 凭证 / 密钥
# -> 应用凭证/密钥文件泄露
(credentials|secrets?|service-account|firebase|google-services|aws-exports)\.(json|ya?ml|toml|ini|conf|cnf|properties|xml|txt)$

# 敏感文件模式 — 配置文件
# -> 应用配置文件泄露
(application|bootstrap|settings|config|local|production|prod|staging|stage|development|dev|test|database|db)\.(json|ya?ml|toml|ini|conf|cnf|properties|xml)$

# 敏感文件模式 — 构建依赖
# -> 构建依赖/锁文件泄露
(composer\.(json|lock)|package(-lock)?\.json|npm-shrinkwrap\.json|yarn\.lock|pnpm-lock\.ya?ml|bun\.lockb?|bower\.json|Gemfile(\.lock)?|go\.(mod|sum|work)|Cargo\.(toml|lock)|pom\.xml|build\.gradle(\.kts)?|settings\.gradle(\.kts)?|gradle\.properties|mvnw|gradlew|Makefile|CMakeLists\.txt|requirements(-[A-Za-z0-9_.-]+)?\.txt|Pipfile(\.lock)?|pyproject\.toml|poetry\.lock|setup\.(py|cfg)|tox\.ini|pytest\.ini|phpunit\.xml(\.dist)?|artisan|manage\.py|wsgi\.py|asgi\.py|celery\.py)$

# 敏感文件模式 — Docker / CI / 进程
# -> Docker/CI/进程配置文件泄露
(Dockerfile(\.[^/]+)?|Containerfile(\.[^/]+)?|\.dockerignore|docker-compose(\.[^/]+)?\.ya?ml|compose(\.[^/]+)?\.ya?ml|Jenkinsfile|Vagrantfile|Procfile|supervisord\.conf|ecosystem\.config\.(js|cjs|mjs|json)|pm2(\.config)?\.(js|json|ya?ml))$

# 敏感文件模式 — K8s / Helm / Ansible
# -> K8s/Helm/Ansible 配置泄露
(Chart\.ya?ml|values(-[A-Za-z0-9_.-]+)?\.ya?ml|kustomization\.ya?ml|helmfile\.ya?ml|ansible\.cfg|inventory(\.ini)?|playbook\.ya?ml)$

# 敏感文件模式 — core dump
# -> Core dump 文件泄露
(core|core\.[0-9]+)$

# 敏感文件模式 — direnv / shell 环境配置（LeakIX 等扫描器常探测 .envrc.local）
# -> direnv 环境配置泄露
\.envrc(\.[a-zA-Z0-9_-]+)*$

# 依赖目录
# -> PHP 依赖目录泄露
/(composer\.(json|lock)|vendor/)
# -> Node.js 依赖锁文件泄露
/(package\.json|package-lock\.json|yarn\.lock|pnpm-lock\.yaml)$
# -> node_modules 目录泄露
^/(node_modules)(/.*)?$

# 系统 shell 执行（路径穿越/命令注入常用目标）

#!/bin/bash
# ============================================================
# WAF 命令行管理工具
# 通过文件管道与运行中的 WAF 通信，无需开放 HTTP 接口
# ============================================================

# 默认使用 waf-cli 所在目录下的 waf-cmd 子目录
# 如需自定义，直接修改下面这行，例如 CMD_DIR="/var/run/waf-cmd"
WAF_DIR=$(cd "$(dirname "$0")" && pwd)
CMD_DIR="$WAF_DIR/waf-cmd"

TIMEOUT=5   # 等待响应超时时间（秒）

# 触发 WAF 执行命令的 URL（多虚拟主机时请改成任意一个经过 WAF 的地址）
WAF_TRIGGER_URL="${WAF_TRIGGER_URL:-http://127.0.0.1/}"

# 输出颜色（仅终端输出时启用，管道输出时自动禁用）
if [ -t 1 ]; then
    COLOR_GREEN='\033[32m'
    COLOR_RED='\033[31m'
    COLOR_YELLOW='\033[33m'
    COLOR_RESET='\033[0m'
else
    COLOR_GREEN=''
    COLOR_RED=''
    COLOR_YELLOW=''
    COLOR_RESET=''
fi

# 自动创建命令管道目录，并尝试按 Nginx worker 用户授权
mkdir -p "$CMD_DIR"
NGINX_USER=$(ps aux 2>/dev/null | grep "nginx: worker" | grep -v grep | awk '{print $1}' | head -1)
if [ -n "$NGINX_USER" ] && [ "$NGINX_USER" != "root" ]; then
    chown "$NGINX_USER:$NGINX_USER" "$CMD_DIR" 2>/dev/null || true
fi
chmod 755 "$CMD_DIR"

CMD="$1"
IP="$2"
ID="$$_$(date +%s%N 2>/dev/null || echo $$)"
REQ_FILE="$CMD_DIR/req-$ID.json"
RES_FILE="$CMD_DIR/res-$ID.json"

usage() {
    echo "WAF Command Line Tool"
    echo ""
    echo "Usage:"
    echo "  $(basename "$0") unban <ip>     解除指定 IP 的 CC 封禁"
    echo "  $(basename "$0") banlist        查看当前被封禁的 IP 列表"
    echo "  $(basename "$0") reload         强制刷新 WAF 规则缓存"
    echo "  $(basename "$0") stats <ip>     查看指定 IP 的 CC 统计"
    echo ""
    echo "Examples:"
    echo "  $(basename "$0") unban 1.2.3.4"
    echo "  $(basename "$0") banlist | jq '.data[] | {ip, remain}'"
    echo ""
    echo "Environment:"
    echo "  WAF_TRIGGER_URL    触发 WAF 执行的 URL，默认 http://127.0.0.1/"
    echo "                     多虚拟主机时请改成任意经过 WAF 的地址"
    exit 1
}

case "$CMD" in
    unban)
        if [ -z "$IP" ]; then
            echo "Error: ip required" >&2
            usage
        fi
        printf '{"cmd":"unban","ip":"%s","id":"%s"}\n' "$IP" "$ID" > "$REQ_FILE"
        ;;
    banlist)
        printf '{"cmd":"banlist","id":"%s"}\n' "$ID" > "$REQ_FILE"
        ;;
    reload)
        printf '{"cmd":"reload","id":"%s"}\n' "$ID" > "$REQ_FILE"
        ;;
    stats)
        if [ -z "$IP" ]; then
            echo "Error: ip required" >&2
            usage
        fi
        printf '{"cmd":"stats","ip":"%s","id":"%s"}\n' "$IP" "$ID" > "$REQ_FILE"
        ;;
    *)
        usage
        ;;
esac

# 发送一个触发请求，让 WAF access 阶段执行命令处理
# 多虚拟主机时，请设置 WAF_TRIGGER_URL 环境变量指向任意经过 WAF 的地址
if [ -n "$WAF_TRIGGER_URL" ]; then
    (sleep 0.2; curl -s -o /dev/null "$WAF_TRIGGER_URL" 2>/dev/null || true) &
fi

# 等待响应
WAIT_MS=$((TIMEOUT * 10))
for i in $(seq 1 $WAIT_MS); do
    if [ -f "$RES_FILE" ]; then
        RES=$(cat "$RES_FILE")
        rm -f "$RES_FILE"
        if echo "$RES" | grep -q '"status":"ok"'; then
            printf '%b%s%b\n' "$COLOR_GREEN" "$RES" "$COLOR_RESET"
        elif echo "$RES" | grep -q '"status":"error"'; then
            printf '%b%s%b\n' "$COLOR_RED" "$RES" "$COLOR_RESET"
        else
            printf '%s\n' "$RES"
        fi
        exit 0
    fi
    sleep 0.1
done

# 超时：清理请求文件并返回错误
rm -f "$REQ_FILE"
printf '%b%s%b\n' "$COLOR_RED" '{"status":"error","message":"timeout waiting for WAF response. ensure nginx is running with WAF loaded, and requests are being processed."}' "$COLOR_RESET"
exit 1
